---
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../../components/ToolCard';
---

<Layout
  title="Free AI Tools — Pricing Calculator, Model Finder & Prompt Library"
  description="Free AI tools: compare LLM pricing, find the right model, and browse curated prompts. No signup required."
  canonical="/tools"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="bg-radial-glow absolute inset-0"></div>
    <div class="bg-grid absolute inset-0"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:py-20 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">
          Free AI <span class="gradient-text">Tools</span>
        </h1>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Everything you need to choose, compare, and use AI models. All free, no signup.
        </p>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <ToolCard
        client:load
        title="AI Model Comparator"
        description="Compare AI model responses side-by-side in real time. Test the same prompt across Gemma, Nemotron, Trinity, and 6 free models."
        href="/#compare"
        accentColor="#6366f1"
        badge="Popular"
        iconPath="M13 10V3L4 14h7v7l9-11h-7z"
      />

      <ToolCard
        client:load
        title="AI Pricing Calculator"
        description="Calculate and compare costs across 25+ AI models. Enter your token usage, see which provider saves you the most."
        href="/tools/ai-pricing-calculator"
        accentColor="#06b6d4"
        badge="New"
        iconPath="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
      />

      <ToolCard
        client:load
        title="AI Model Finder"
        description="Answer 4 quick questions and get personalized AI model recommendations. Find the perfect model for your specific needs."
        href="/tools/ai-model-finder"
        accentColor="#a855f7"
        badge="New"
        iconPath="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      />

      <ToolCard
        client:load
        title="AI Prompt Library"
        description="Browse 40+ curated prompts for writing, coding, analysis, and more. Copy any prompt and test it in our comparator."
        href="/tools/prompt-library"
        accentColor="#22c55e"
        badge="New"
        iconPath="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
      />
    </div>
  </section>

  <!-- SEO content -->
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="section-divider mb-12"></div>
    <div class="prose prose-invert max-w-none prose-headings:font-bold prose-p:text-text-secondary prose-a:text-accent">
      <h2>Why Use AI Prompt Race Tools?</h2>
      <p>
        Picking the right AI model is harder than it sounds. There are dozens of options, each with different strengths, speeds, and price points. Our tools help you cut through the noise and make informed decisions — without spending hours reading benchmarks or signing up for anything.
      </p>
      <p>
        The <strong>Model Comparator</strong> lets you test real prompts side by side. The <strong>Pricing Calculator</strong> shows you exactly what each model costs for your usage. The <strong>Model Finder</strong> recommends models based on what you actually need. And the <strong>Prompt Library</strong> gives you tested, ready-to-use prompts across 6 categories.
      </p>
      <p>
        All tools are free, work instantly in your browser, and require zero signup. Built for developers, writers, and anyone exploring AI.
      </p>
    </div>
  </section>
</Layout>
