---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — AI Prompt Race" description="The page you're looking for doesn't exist.">
  <section class="relative overflow-hidden">
    <div class="bg-grid absolute inset-0"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-32 sm:px-6 sm:py-48 lg:px-8 text-center">
      <p class="text-accent font-mono text-lg font-semibold mb-4">404</p>
      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight">Page not found</h1>
      <p class="mt-6 text-lg text-text-secondary max-w-lg mx-auto">
        This page doesn't exist. Maybe the URL changed, or maybe it never existed in the first place.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3.5 text-base font-semibold text-white hover:bg-accent-light transition-all hover:shadow-lg hover:shadow-accent/25">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Compare AI Models
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 rounded-xl border border-border px-8 py-3.5 text-base font-medium text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors">
          Read the Blog
        </a>
      </div>
    </div>
  </section>
</Layout>
