---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['all', 'comparisons', 'guides', 'news', 'tutorials'];

const categoryColors: Record<string, string> = {
  comparisons: 'text-accent-2 border-accent-2/30 bg-accent-2/5',
  guides: 'text-accent border-accent/30 bg-accent/5',
  news: 'text-success border-success/30 bg-success/5',
  tutorials: 'text-accent-3 border-accent-3/30 bg-accent-3/5',
};
---

<Layout title="Blog — AI Model Reviews, Comparisons & Guides" description="In-depth AI model reviews, head-to-head comparisons, and practical guides to help you choose the right AI tool." canonical="/blog">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">
        AI <span class="gradient-text">Reviews & Guides</span>
      </h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        In-depth comparisons, honest reviews, and practical guides to find the best AI for your needs.
      </p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-10">
      {categories.map(cat => (
        <a
          href={cat === 'all' ? '/blog' : `/blog/category/${cat}`}
          class="text-sm rounded-full border border-border px-4 py-1.5 text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors capitalize"
        >
          {cat}
        </a>
      ))}
    </div>

    <!-- Posts Grid -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="glass-card rounded-xl p-6 flex flex-col group">
            <div class="flex items-center gap-2 mb-3">
              <span class={`text-xs font-medium border rounded-full px-2.5 py-0.5 capitalize ${categoryColors[post.data.category] || 'text-text-muted border-border'}`}>
                {post.data.category}
              </span>
              <time datetime={post.data.date.toISOString()} class="text-xs text-text-muted">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h2 class="text-lg font-bold group-hover:text-accent transition-colors leading-snug mb-2">
              {post.data.title}
            </h2>
            <p class="text-sm text-text-secondary leading-relaxed flex-1">
              {post.data.description}
            </p>
            <div class="mt-4 flex items-center gap-1 text-xs text-accent font-medium">
              Read more
              <svg class="h-3.5 w-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 mx-auto mb-4">
          <svg class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-2">Coming Soon</h2>
        <p class="text-text-secondary max-w-md mx-auto">
          We're working on in-depth AI model reviews and comparison guides. Check back soon!
        </p>
        <a href="/#compare" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-2.5 text-sm font-semibold text-white hover:bg-accent-light transition-all">
          Try the Comparator
        </a>
      </div>
    )}
  </section>
</Layout>
