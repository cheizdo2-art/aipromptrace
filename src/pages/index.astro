---
import Layout from '../layouts/Layout.astro';
import ModelComparator from '../components/ModelComparator';
---

<Layout title="AI Prompt Race — Compare AI Models Side-by-Side for Free">
  <!-- Schema.org SoftwareApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "AI Prompt Race",
    "description": "Free AI model comparison tool. Test prompts across multiple AI models side-by-side in real time.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web-based",
    "url": "https://aipromptrace.com",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Side-by-side AI model comparison",
      "Real-time streaming responses",
      "6 free open-source AI models",
      "No signup required",
      "AI pricing calculator",
      "AI model finder quiz",
      "Prompt template library"
    ]
  })} />

  <!-- Schema.org FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does AI Prompt Race work?",
        "acceptedAnswer": { "@type": "Answer", "text": "Type a prompt, select 2-4 AI models, and see their responses streaming side-by-side in real time. Compare quality, speed, and style instantly." }
      },
      {
        "@type": "Question",
        "name": "Is AI Prompt Race free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, completely free. No signup, no API keys, no credit cards required. You get 200 free comparisons per day." }
      },
      {
        "@type": "Question",
        "name": "What AI models can I compare?",
        "acceptedAnswer": { "@type": "Answer", "text": "You can compare 6 free open-source models: Gemma 3 12B (Google), Nemotron 30B and 9B (NVIDIA), Trinity Large 400B and Trinity Mini (Arcee AI), and GLM 4.5 Air (Zhipu AI)." }
      },
      {
        "@type": "Question",
        "name": "Which free AI model is the best?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on your task. Trinity Large 400B is best for complex reasoning, Nemotron 30B for balanced quality, Gemma 3 12B and Nemotron 9B for speed, and GLM 4.5 Air for multilingual and agent tasks." }
      }
    ]
  })} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-radial-glow">
    <div class="bg-grid absolute inset-0"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
      <div class="text-center">
        <div class="animate-fade-in-up opacity-0 inline-flex items-center gap-2 rounded-full border border-border bg-bg-secondary/50 px-4 py-1.5 mb-8">
          <span class="h-2 w-2 rounded-full bg-success animate-pulse"></span>
          <span class="text-sm text-text-secondary">Free &bull; No signup &bull; 6 AI models</span>
        </div>

        <h1 class="animate-fade-in-up opacity-0 animate-delay-100 text-4xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight">
          Race your prompts<br />
          <span class="gradient-text">across AI models</span>
        </h1>

        <p class="animate-fade-in-up opacity-0 animate-delay-200 mt-6 text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
          Type one prompt. Pick 2-4 AI models. See their responses side-by-side in real time.
          Find the best model for every task — completely free.
        </p>

        <div class="animate-fade-in-up opacity-0 animate-delay-300 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#compare" class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3.5 text-base font-semibold text-white hover:bg-accent-light transition-all hover:shadow-lg hover:shadow-accent/25 pulse-glow">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Start Comparing — Free
          </a>
          <a href="/blog" class="inline-flex items-center gap-2 rounded-xl border border-border px-8 py-3.5 text-base font-medium text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors">
            Read Reviews
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparator Section -->
  <section id="compare" class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="glass-card rounded-2xl p-6 sm:p-8">
      <ModelComparator client:load />
    </div>
  </section>

  <!-- Section Divider -->
  <div class="mx-auto max-w-4xl px-8"><div class="section-divider"></div></div>

  <!-- Features Section -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold">Why <span class="gradient-text">AI Prompt Race</span>?</h2>
      <p class="mt-4 text-text-secondary max-w-2xl mx-auto">Stop guessing which AI model is best. Test them all at once.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="glass-card rounded-xl p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 mb-4">
          <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Side-by-Side</h3>
        <p class="text-sm text-text-secondary leading-relaxed">Compare 2-4 AI models simultaneously. See which one writes better, codes faster, or explains clearer.</p>
      </div>

      <div class="glass-card rounded-xl p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-2/10 mb-4">
          <svg class="h-5 w-5 text-accent-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">No Signup Required</h3>
        <p class="text-sm text-text-secondary leading-relaxed">Just type and compare. No accounts, no API keys, no credit cards. Free and instant.</p>
      </div>

      <div class="glass-card rounded-xl p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-3/10 mb-4">
          <svg class="h-5 w-5 text-accent-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">6 Free Models</h3>
        <p class="text-sm text-text-secondary leading-relaxed">Gemma, Nemotron, Trinity, GLM — 6 reliable free open-source models, always online.</p>
      </div>
    </div>
  </section>

  <!-- Section Divider -->
  <div class="mx-auto max-w-4xl px-8"><div class="section-divider"></div></div>

  <!-- Models Section -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold">Available <span class="gradient-text">Models</span></h2>
      <p class="mt-4 text-text-secondary">All models are free to use. Powered by open-source AI.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        { name: "Gemma 3 12B", provider: "Google", color: "#0F9D58", category: "Fast", params: "12B", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>` },
        { name: "Nemotron 30B", provider: "NVIDIA", color: "#76B900", category: "Reasoning", params: "30B", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8.948 8.798v-1.43a6.7 6.7 0 01.424-.018c3.922-.124 6.417 3.396 6.417 3.396s-2.728 3.882-5.63 3.882c-.428 0-.837-.066-1.211-.196v-4.238l-.002-.004c-1.728.142-2.063 1.386-2.063 1.386l-2.07-1.722S6.49 7.9 8.948 8.798zm0 7.424v.89a10.478 10.478 0 01-4.107-1.291l.764-.877s1.474.86 3.343 1.054v.224zm0-5.478v1.632c-.953-.146-1.47.65-1.47.65l-1.26-.93s.878-1.499 2.73-1.352zm5.652 1.4s-1.726 2.632-4.441 2.874v.862c3.66-.324 6.794-3.736 6.794-3.736s-1.804-3.636-5.377-4.384v.934c2.334.538 3.024 3.45 3.024 3.45zM22 2v20H2V2h20zm-1.2 1.2H3.2v17.6h17.6V3.2z"/></svg>` },
        { name: "Nemotron 9B", provider: "NVIDIA", color: "#8DC63F", category: "Fast", params: "9B", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8.948 8.798v-1.43a6.7 6.7 0 01.424-.018c3.922-.124 6.417 3.396 6.417 3.396s-2.728 3.882-5.63 3.882c-.428 0-.837-.066-1.211-.196v-4.238l-.002-.004c-1.728.142-2.063 1.386-2.063 1.386l-2.07-1.722S6.49 7.9 8.948 8.798zm0 7.424v.89a10.478 10.478 0 01-4.107-1.291l.764-.877s1.474.86 3.343 1.054v.224zm0-5.478v1.632c-.953-.146-1.47.65-1.47.65l-1.26-.93s.878-1.499 2.73-1.352zm5.652 1.4s-1.726 2.632-4.441 2.874v.862c3.66-.324 6.794-3.736 6.794-3.736s-1.804-3.636-5.377-4.384v.934c2.334.538 3.024 3.45 3.024 3.45zM22 2v20H2V2h20zm-1.2 1.2H3.2v17.6h17.6V3.2z"/></svg>` },
        { name: "Trinity Large", provider: "Arcee AI", color: "#E74C3C", category: "General", params: "400B", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 19h20L12 2zm0 4l6.93 12H5.07L12 6z"/><path d="M12 10l3 6H9l3-6z"/></svg>` },
        { name: "Trinity Mini", provider: "Arcee AI", color: "#FF6B6B", category: "Efficient", params: "", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 19h20L12 2zm0 4l6.93 12H5.07L12 6z"/><path d="M12 10l3 6H9l3-6z"/></svg>` },
        { name: "GLM 4.5 Air", provider: "Zhipu AI", color: "#00BCF2", category: "Agent", params: "", logo: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16v3H8.5l11 10H20v3H4v-3h11L4.5 7H4V4z"/></svg>` },
      ].map((model) => (
        <div class="model-card glass-card rounded-xl p-4 group cursor-default" style={`--card-color: ${model.color}`}>
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg transition-all group-hover:scale-110" style={`background: ${model.color}15; color: ${model.color}`}>
              <Fragment set:html={model.logo.replace('viewBox', `class="h-4.5 w-4.5" viewBox`)} />
            </div>
            {model.params && (
              <span class="ml-auto text-xs font-bold param-highlight opacity-40 group-hover:opacity-80 transition-opacity" style={`color: ${model.color}`}>{model.params}</span>
            )}
          </div>
          <h3 class="text-sm font-semibold" style="font-family: var(--font-heading)">{model.name}</h3>
          <p class="text-xs text-text-muted mt-0.5">{model.provider}</p>
          <span
            class="inline-block mt-2.5 text-[10px] font-medium rounded-full px-2.5 py-0.5 border transition-colors"
            style={`border-color: ${model.color}30; color: ${model.color}; background: ${model.color}08`}
          >
            {model.category}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- Section Divider -->
  <div class="mx-auto max-w-4xl px-8"><div class="section-divider"></div></div>

  <!-- CTA Section -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-radial-glow border border-border p-8 sm:p-12 text-center">
      <div class="bg-grid absolute inset-0"></div>
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-bold">Ready to find your perfect AI?</h2>
        <p class="mt-4 text-text-secondary max-w-xl mx-auto">Stop paying for models you don't need. Compare them all for free and pick the winner.</p>
        <a href="#compare" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3.5 text-base font-semibold text-white hover:bg-accent-light transition-all hover:shadow-lg hover:shadow-accent/25">
          Start Racing — It's Free
        </a>
      </div>
    </div>
  </section>
</Layout>
